{
  "extends": "@cardinalxchange/config/tsconfig/next.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["./app/*"],
      "@/backend/*": ["./backend/*"],
      "@/frontend/*": ["./frontend/*"],
      "@/features/*": ["./frontend/features/*"],
      "@/utils/*": ["./shared/utils/*"],
      "@/data/*": ["./shared/data/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

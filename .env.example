NEXT_PUBLIC_APP_URL=http://localhost:3000
POSTGRES_PORT=54322
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/cardinalxchange
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/cardinalxchange

# CXC AI (OpenAI). Without OPENAI_API_KEY, the chat falls back to an
# extractive answer assembled from public Q&A retrieval — no 500.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_RESEARCH_MODEL=gpt-5-mini

# Optional bounded web context for CXC AI. Leave empty to disable.
WEB_CONTEXT_ENDPOINT=
WEB_CONTEXT_API_KEY=

# Better Auth
# BETTER_AUTH_SECRET — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Dev-only viewer stub. Set AUTH_DEV_BYPASS=1 to keep the DEV_VIEWER_*
# shortcut working alongside real Better Auth sessions in development.
# NEVER set these in production.
AUTH_DEV_BYPASS=
DEV_VIEWER_ID=dev-viewer
DEV_VIEWER_NAME=Stanford Student
DEV_VIEWER_META=

# Google OAuth (free — create at console.cloud.google.com)
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stanford SSO (placeholders — optional later upgrade from Google OAuth)
STANFORD_SAML_ENTITY_ID=
STANFORD_SAML_SSO_URL=
STANFORD_SAML_CERT=
STANFORD_OIDC_ISSUER=
STANFORD_OIDC_CLIENT_ID=
STANFORD_OIDC_CLIENT_SECRET=
